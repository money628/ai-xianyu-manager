# AI店长 v1.2 — 环境变量示例
# 复制为 .env 后修改真实值

# 部署环境
APP_ENV=production
PUBLIC_BASE_URL=http://localhost:8501
TZ=Asia/Shanghai

# 数据库 (Docker内路径)
DATABASE_URL=/app/data/ai_storekeeper.db

# PDD 开放平台 API (主账号)
PDD_CLIENT_ID=
PDD_CLIENT_SECRET=
PDD_ACCESS_TOKEN=
PDD_REFRESH_TOKEN=

# PDD 多账号池 (可选)
PDD_ACCOUNT_1_CLIENT_ID=
PDD_ACCOUNT_1_CLIENT_SECRET=
PDD_ACCOUNT_1_PID=
PDD_ACCOUNT_2_CLIENT_ID=
PDD_ACCOUNT_2_CLIENT_SECRET=
PDD_ACCOUNT_2_PID=

# 推送 (可选)
DINGTALK_WEBHOOK=
DINGTALK_SECRET=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
SERVERCHAN_SENDKEY=
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_TO=

# 存储目录 (相对路径)
STORAGE_DIR=./storage
